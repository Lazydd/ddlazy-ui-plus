{
	"name": "ddlazy-ui-plus",
	"version": "0.0.2",
	"type": "module",
	"description": "A Component Library for Vue3.",
	"main": "lib/ddlazy-ui-plus.es",
	"engines": {
		"node": "^18.0.0 || >=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Lazydd/ddlazy-ui-plus.git"
	},
	"files": [
		"lib"
	],
	"scripts": {
		"dev": "pnpm build:ui && vitepress dev docs",
		"dev:ui": "vite",
		"build:ui": "vite build && pnpm build:dts",
		"build:doc": "pnpm build:ui && vitepress build docs",
		"build:dts": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.packages.json",
		"fmt": "oxfmt packages/**/*",
		"fmt:check": "oxfmt --check packages/**/*",
		"serve": "vitepress serve docs",
		"preview": "vitepress preview docs"
	},
	"author": "ddlazy",
	"license": "MIT",
	"private": true,
	"keywords": [
		"vue3",
		"组件库"
	],
	"devDependencies": {
		"@ddlazy/utils": "^0.0.7",
		"@iconify/json": "^2.2.471",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.6.2",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitejs/plugin-vue-jsx": "^5.1.5",
		"@vueuse/components": "^14.3.0",
		"@vueuse/core": "^14.3.0",
		"feed": "^5.2.1",
		"markdown-it": "^14.2.0",
		"md5": "^2.3.0",
		"oxfmt": "^0.55.0",
		"sass": "^1.100.0",
		"simple-git": "^3.36.0",
		"terser": "^5.48.0",
		"unocss": "^66.6.7",
		"vite": "^8.0.16",
		"vitepress": "^1.6.4",
		"vitepress-theme-demoblock-fork": "^3.1.3",
		"vue-tsc": "^3.3.4"
	},
	"dependencies": {
		"dayjs": "^1.11.21",
		"vue": "^3.5.35"
	},
	"browserslist": [
		"> 1%",
		"last 2 versions",
		"not dead"
	]
}
