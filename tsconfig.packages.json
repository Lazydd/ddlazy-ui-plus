{
	"compilerOptions": {
		"outDir": "lib",
		"rootDir": "./packages",
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"strict": false,
		"jsx": "preserve",
		"types": ["vite/client"],
		"skipLibCheck": true,
		"declaration": true,
		"declarationDir": "lib",
		"emitDeclarationOnly": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@theme/*": ["./.vitepress/theme/*"],
			"@/lib/*": ["./lib/*"],
			"@/packages/*": ["./packages/*"],
			"@/docs/*": ["./docs/*"]
		}
	},
	"include": ["packages/**/*"],
	"exclude": ["node_modules/**/*"]
}
